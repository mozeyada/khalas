ENVIRONMENT=development
PROJECT_NAME=khalas-api
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:3000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/khalas?retryWrites=true&w=majority&appName=Khalas
MONGODB_DB_NAME=khalas
JWT_SECRET_KEY=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET_KEY=change-me-refresh-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_MINUTES=10
